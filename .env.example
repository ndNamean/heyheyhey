# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your InstantDB app ID (public — safe to expose in browser)
VITE_INSTANT_APP_ID=19ae2c0e-0e3c-468a-8d28-709404385128

# Your Google OAuth Client ID (from Google Cloud Console)
# Used by @react-oauth/google to render the Sign in with Google button
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# InstantDB admin token — ONLY used by the seed-owner script, never in browser code
# Generate at: https://www.instantdb.com/dash?s=admin-tokens
INSTANT_ADMIN_TOKEN=YOUR_ADMIN_TOKEN_HERE
