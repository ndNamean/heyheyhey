{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_INSTANT_APP_ID": "f7ac027e-2079-41eb-8f34-aa0e4543ca71",
    "INSTANT_APP_ID": "f7ac027e-2079-41eb-8f34-aa0e4543ca71",
    "INSTANT_ADMIN_TOKEN": "58ea1b1e-0565-487a-89d8-4a1f506c947a",
    "APP_ORIGIN": "https://restaurant-ops-instant.vercel.app"
  },
  "crons": [
    {
      "path": "/api/cleanup-photos",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/export",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/upload-photo.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/upload-logo.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/avatar.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/image-proxy.js": {
      "maxDuration": 15,
      "memory": 256
    },
    "api/video-proxy.js": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/cleanup-photos.js": {
      "maxDuration": 60
    },
    "api/export.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
